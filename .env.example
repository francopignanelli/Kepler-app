# ============================================================================
# Kepler — variables de entorno
# Copiá este archivo a .env.local y completá tus keys.
# Las keys viven SOLO en el servidor: nunca se exponen al frontend.
# ============================================================================

# WeatherAPI.com — clima, forecast horario y astronomía (Sol/Luna).
# Gratis en https://www.weatherapi.com/ (1M llamadas/mes en el plan free).
# OPCIONAL: sin esta key el clima funciona igual vía Open-Meteo (sin key);
# la key agrega fase e iluminación lunar al análisis de visibilidad.
WEATHER_API_KEY=

# OpenWeatherMap — clima actual con íconos y forecast 5 días / 3 horas.
# Gratis en https://home.openweathermap.org/ (los endpoints 2.5 del plan free;
# One Call 3.0 NO está incluido en el plan free). Las keys nuevas tardan
# hasta ~2 horas en activarse. OPCIONAL: sin esta key se usa Open-Meteo.
OPENWEATHER_API_KEY=

# N2YO.com — explorador de satélites ("above") y predicción de pasadas visuales.
# Gratis en https://www.n2yo.com/api/ (límite: 100 req/hora en visualpasses,
# 30s de cache propio para /above). Sin esta key, el explorador de satélites
# queda deshabilitado y las pasadas se calculan localmente con SGP4 + TLE de
# CelesTrak (sin registro), que es el modo por defecto recomendado.
N2YO_API_KEY=
